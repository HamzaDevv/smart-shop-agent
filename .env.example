# =============================================================
#  Smart Shop AI — Environment Variables
#  Copy this file to .env and fill in your actual keys/values.
#  cp .env.example .env
# =============================================================

# ── AI Model API Keys ────────────────────────────────────────
# Google Gemini (primary model) — get from https://aistudio.google.com/apikey
GOOGLE_API_KEY="your-google-api-key-here"

# Groq (fast inference, optional) — get from https://console.groq.com/keys
GROQ_API_KEY="your-groq-api-key-here"

# Tavily (web search fallback) — get from https://tavily.com
TAVILY_API_KEY="your-tavily-api-key-here"

# ── PostgreSQL Database ──────────────────────────────────────
# Main business database (inventory, sales, customers)
DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/smartinventory"

# Vector database (document embeddings, requires pgvector extension)
V_DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/vector_db"

# ── Optional ─────────────────────────────────────────────────
# Path to a sample invoice document for testing
INVOICE_PATH="documents/sample_invoice.pdf"
